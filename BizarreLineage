												end
											end
										end
									end
								end
							end
						end
					end
					return
				end

				local NearestPvPBoard = nil
				local ShortestDistance = math.huge

				for _, PvPBoard in pairs(PvPBoardFolder:GetChildren()) do
					if PvPBoard:IsA("Model") and PvPBoard.Name == "PvP Mission Board" then
						local Distance = (PvPBoard.PrimaryPart.Position - HumanoidRootPart.Position).Magnitude

						if Distance < ShortestDistance then					
							ShortestDistance = Distance
							NearestPvPBoard = PvPBoard
						end
					end
				end

				if NearestPvPBoard then
					if ShortestDistance < 15 then
						Camera.CameraType = Enum.CameraType.Scriptable
						Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position,NearestPvPBoard.PrimaryPart.Position)

						Prompt(NearestPvPBoard)
					else
						HumanoidRootPart.CFrame = CFrame.new(NearestPvPBoard.PrimaryPart.Position) + Vector3.new(0, 0, -10)
					end
				end
			end
		end)

		Selection.MouseButton1Click:Connect(function()
			Selection.List.Visible = not Selection.List.Visible
		end)

		Button.MouseButton1Click:Connect(function()
			if Debounce then return end
			Debounce = true
			Activate = not Activate
			AutoLvlUp.Activate = Activate
			local LatestConfig = DataStore:Load()
			LatestConfig.AutoLvlUp = LatestConfig.AutoLvlUp or {}
			local DefaultColor = AutoLvlUpFrame.Button.Frame.BackgroundColor3

			LatestConfig.AutoLvlUp.Activate = Activate

			if Activate then
				if AutoRaid.Activate or Account == "" then
					Button.Frame.BackgroundColor3 = Color3.fromRGB(188, 24, 26)
					task.wait(0.5)

					Button.Frame.BackgroundColor3 = DefaultColor
					return
				end

				local pos = UDim2.new(0.8, 0, 0.5, 0)
				LatestConfig.AutoLvlUp.ButtonPosition = {0.8, 0, 0.5, 0}
				local tween = TweenService:Create(Button.Frame, TweenInfo.new(0.15), {Position = pos})
				tween:Play()
			else
				local pos = UDim2.new(0.2, 0, 0.5, 0)
				LatestConfig.AutoLvlUp.ButtonPosition = {0.2, 0, 0.5, 0}
				local tween = TweenService:Create(Button.Frame, TweenInfo.new(0.15), {Position = pos})
				tween:Play()
			end

			DataStore:Save(LatestConfig)
			Config = LatestConfig

			task.delay(0.5, function()
				Debounce = false
			end)
		end)

		WhichAccount()
		RestoreUI()

		return AutoLvlUp
	end;
};
