G2L_MODULES[G2L["6"]] = {
	Closure = function()
		local script = G2L["6"];--// SERVICES --\\
		local Players = game:GetService("Players")
		local TweenService = game:GetService("TweenService")
		local UserInputService = game:GetService("UserInputService")
		local RunService = game:GetService("RunService")

		--// VARIABLES --\\
		local Player = Players.LocalPlayer
		local PlayerGui = Player.PlayerGui

		local Dragging = false
		local DragStart
		local StartPos
		local CurrentTween

		--// INTERFACE --\\
		local BizarreLineage = CoreGui.BizarreLineage
		local Holder = BizarreLineage.Holder
		local Title = Holder.Top.Title
		local ContentFrame = Holder.Under.Content
		local Scrolling = Holder.Under.Section.Scrolling
		local DeleteButton = Holder.Under.Section.Scrolling.DeleteScript
		local MainButton = Holder.Under.Section.Scrolling.MainButton

		local Main = {}

		BizarreLineage.Enabled = true
		Title.Text = Player.Name.. " | Bizarre Lineage"

		local function SectionList()
			for _, Buttons in pairs(Scrolling:GetChildren()) do
				if Buttons:IsA("TextButton") then
					local Frame = Buttons:FindFirstChild("Frame")
					Frame.MouseEnter:Connect(function()
						local tween = TweenService:Create(Frame, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(20,20,20)}) tween:Play()
					end)

					Frame.MouseLeave:Connect(function()
						local tween = TweenService:Create(Frame, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(255, 255, 255)}) tween:Play()
					end)
				end
			end
		end

		SectionList()

		--// DRAGGING --\\
		local function Update(Input)
			local Delta = Input.Position - DragStart

			local TargetPos = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + Delta.X, StartPos.Y.Scale, StartPos.Y.Offset + Delta.Y)

			if CurrentTween then
				CurrentTween:Cancel()
			end

			CurrentTween = TweenService:Create(Holder, TweenInfo.new(0.15), {Position = TargetPos})
			CurrentTween:Play()
		end

		Holder.InputBegan:Connect(function(Input)
			if Input.UserInputType == Enum.UserInputType.MouseButton1 then
				Dragging = true
				DragStart = Input.Position
				StartPos = Holder.Position

				Input.Changed:Connect(function()
					if Input.UserInputState == Enum.UserInputState.End then
						Dragging = false
					end
				end)
			end	
		end)

		Holder.InputChanged:Connect(function(Input)
			if Input.UserInputType == Enum.UserInputType.MouseMovement then
				if Dragging then
					Update(Input)
				end
			end
		end)


		UserInputService.InputChanged:Connect(function(Input)
			if Dragging and Input.UserInputType == Enum.UserInputType.MouseMovement then
				Update(Input)
			end
		end)

		UserInputService.InputBegan:Connect(function(Input)
			if Input.KeyCode == Enum.KeyCode.LeftAlt then
				BizarreLineage.Enabled = not BizarreLineage.Enabled
			end
		end)


		MainButton.MouseButton1Click:Connect(function()
			if not ContentFrame.Visible then
				ContentFrame.Visible = true
			end
		end)

		DeleteButton.MouseButton1Click:Connect(function()
			BizarreLineage:Destroy()
		end)

		Main.Initialize = function()
			BizarreLineage.Enabled = true
			warn("Initialized Bizarre Lineage script")

			for i, module in pairs(script:GetChildren()) do
				if module:IsA("ModuleScript") then
					require(module)
				end
			end
		end

		return Main
	end;
};
