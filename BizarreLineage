			if Method == "" then return end
			if CurrentTarget then if (AutoMeditation.Activate and not CurrentTarget.Name:find("%." .. Player.Name .. " entity clone")) then CurrentTarget = nil return end end

			local NearestTarget = nil
			local TargetShortestDistance = math.huge

			for _, Target in pairs(Live:GetChildren()) do
				if Target:IsA("Model") and Target ~= Player.Character and Target.Name ~= "Server" then
					local IsPlayer = Players:GetPlayerFromCharacter(Target)

					if not IsPlayer and Target.PrimaryPart then
						local IsClone = Target.Name:find("%." .. Player.Name .. " entity clone")

						if (not AutoMeditation.Activate) or (AutoMeditation.Activate and IsClone) then
							local Distance = (Target.PrimaryPart.Position - HumanoidRootPart.Position).Magnitude

							if Distance < TargetShortestDistance then
								TargetShortestDistance = Distance
								NearestTarget = Target
							end
						end
					end
				end
			end

			CurrentTarget = NearestTarget
			if not CurrentTarget or not CurrentTarget.PrimaryPart then return end

			local TargetPosition = CurrentTarget.PrimaryPart.Position

			if Method == "Below" then
				local Pos = TargetPosition + Vector3.new(0, -7.5, 0)
