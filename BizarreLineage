				ProximityPrompt.Triggered:Connect(function()
					Triggered = true
					ProximityPrompt.RequiresLineOfSight = true
					ProximityPrompt.MaxActivationDistance = DefaultProximityPromptDist
					for _, PvPBoard in pairs(PvPBoardFolder:GetChildren()) do
